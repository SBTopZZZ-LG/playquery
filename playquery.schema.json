{
  "$defs": {
    "CopilotOptions": {
      "description": "Pydantic model for Copilot AI provider configuration.",
      "properties": {
        "type": {
          "const": "copilot",
          "default": "copilot",
          "title": "Type",
          "type": "string"
        },
        "model": {
          "default": "claude-sonnet-4.6",
          "title": "Model",
          "type": "string"
        },
        "timeout": {
          "default": 300.0,
          "title": "Timeout",
          "type": "number"
        },
        "github_token": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Github Token"
        }
      },
      "title": "CopilotOptions",
      "type": "object"
    },
    "LoggingConfig": {
      "description": "Logging configuration for PlayQuery runtime output.",
      "properties": {
        "level": {
          "const": "DEBUG",
          "default": "DEBUG",
          "title": "Level",
          "type": "string"
        }
      },
      "title": "LoggingConfig",
      "type": "object"
    },
    "PatchrightOptions": {
      "description": "Pydantic model for Patchright scraper configuration.",
      "properties": {
        "type": {
          "const": "patchright",
          "default": "patchright",
          "title": "Type",
          "type": "string"
        },
        "headless": {
          "default": true,
          "title": "Headless",
          "type": "boolean"
        },
        "channel": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Channel"
        },
        "locale": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": "en-US",
          "title": "Locale"
        },
        "timeout": {
          "default": 30.0,
          "title": "Timeout",
          "type": "number"
        }
      },
      "title": "PatchrightOptions",
      "type": "object"
    },
    "SearXNGOptions": {
      "description": "Pydantic model for SearXNG engine configuration.",
      "properties": {
        "type": {
          "const": "searxng",
          "default": "searxng",
          "title": "Type",
          "type": "string"
        },
        "base_url": {
          "format": "uri",
          "minLength": 1,
          "title": "Base Url",
          "type": "string"
        },
        "user_agent": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "User Agent"
        },
        "timeout": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": 30.0,
          "title": "Timeout"
        }
      },
      "required": [
        "base_url"
      ],
      "title": "SearXNGOptions",
      "type": "object"
    }
  },
  "description": "Root configuration model for playquery.yaml.",
  "properties": {
    "search_engine": {
      "discriminator": {
        "mapping": {
          "searxng": "#/$defs/SearXNGOptions"
        },
        "propertyName": "type"
      },
      "oneOf": [
        {
          "$ref": "#/$defs/SearXNGOptions"
        }
      ],
      "title": "Search Engine"
    },
    "scraper": {
      "anyOf": [
        {
          "discriminator": {
            "mapping": {
              "patchright": "#/$defs/PatchrightOptions"
            },
            "propertyName": "type"
          },
          "oneOf": [
            {
              "$ref": "#/$defs/PatchrightOptions"
            }
          ]
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Scraper"
    },
    "ai": {
      "discriminator": {
        "mapping": {
          "copilot": "#/$defs/CopilotOptions"
        },
        "propertyName": "type"
      },
      "oneOf": [
        {
          "$ref": "#/$defs/CopilotOptions"
        }
      ],
      "title": "Ai"
    },
    "logging": {
      "$ref": "#/$defs/LoggingConfig"
    }
  },
  "required": [
    "search_engine",
    "ai"
  ],
  "title": "PlayQueryConfig",
  "type": "object"
}
